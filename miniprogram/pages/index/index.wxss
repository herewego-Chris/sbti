.hero-title {
  font-size: 56rpx;
  line-height: 1.3;
  font-weight: 700;
  text-align: center;
  letter-spacing: 1rpx;
}

.intro-card {
  min-height: calc(100vh - 48rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 16% 14%, rgba(127, 165, 134, 0.14), rgba(127, 165, 134, 0) 42%),
    radial-gradient(circle at 86% 80%, rgba(127, 165, 134, 0.12), rgba(127, 165, 134, 0) 38%),
    linear-gradient(180deg, #ffffff, #f7fbf8);
}

.intro-inner {
  width: 100%;
  max-width: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-sub {
  margin-top: 16rpx;
  margin-bottom: 36rpx;
  font-size: 27rpx;
  color: #6a786f;
  text-align: center;
  line-height: 1.5;
}

.intro-actions {
  justify-content: center;
}

.topbar {
  margin-bottom: 20rpx;
}

.progress {
  background: #e9edf3;
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #0f172a, #334155);
}

.progress-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #556070;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question {
  border: 1rpx solid #e8edf4;
  border-radius: 16rpx;
  padding: 18rpx;
}

.question-meta {
  display: flex;
  justify-content: space-between;
  color: #6b7685;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.badge {
  background: #ecf1f8;
  color: #111827;
  border-radius: 10rpx;
  padding: 4rpx 12rpx;
}

.question-title {
  font-size: 30rpx;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option {
  border: 1rpx solid #dfe6ef;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  background: #ffffff;
}

.option.selected {
  border-color: #0f172a;
  background: #f5f7fb;
}

.option-code {
  min-width: 38rpx;
  height: 38rpx;
  border-radius: 20rpx;
  background: #ecf1f8;
  text-align: center;
  line-height: 38rpx;
  color: #111827;
  font-size: 22rpx;
}

.option-label {
  font-size: 27rpx;
  line-height: 1.45;
}

.actions-bottom {
  margin-top: 20rpx;
}

.hint {
  color: #5f6c7d;
  font-size: 24rpx;
  margin-bottom: 14rpx;
}

.result-top {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.poster-box {
  border-radius: 18rpx;
  border: 1rpx solid #dbe8dd;
  background:
    radial-gradient(circle at top right, rgba(127, 165, 134, 0.16), rgba(127, 165, 134, 0) 40%),
    linear-gradient(180deg, #ffffff, #f7fbf8);
  color: #304034;
  padding: 22rpx;
  overflow: hidden;
}

.poster-code {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.poster-image {
  width: 100%;
  height: 740rpx;
  border-radius: 14rpx;
  border: 1rpx solid #dbe8dd;
  background: #ffffff;
}

.poster-caption {
  margin-top: 8rpx;
  color: #6a786f;
  line-height: 1.45;
}

.type-kicker {
  font-size: 25rpx;
  color: #667489;
}

.type-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.match {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.type-subname {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #58667b;
  line-height: 1.45;
}

.secondary-type {
  margin-top: 8rpx;
  color: #45556d;
  font-size: 24rpx;
}

.analysis-box,
.dim-box,
.note-box {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebf0f6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.paragraph {
  line-height: 1.55;
  color: #2f3a48;
}

.dim-item {
  border: 1rpx solid #e8edf4;
  border-radius: 14rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
}

.dim-item-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dim-item-name {
  font-weight: 600;
}

.dim-item-score {
  color: #526176;
  font-size: 24rpx;
}

.result-actions {
  margin-top: 12rpx;
}

.save-tip {
  margin-top: 12rpx;
  color: #55657b;
  font-size: 24rpx;
  line-height: 1.5;
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 690px;
  height: 3600px;
  opacity: 0;
  pointer-events: none;
}
