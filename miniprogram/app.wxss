page {
  background: #f3f5f8;
  color: #16181d;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 24, 39, 0.08);
}

.btn-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.btn-primary,
.btn-secondary {
  border: none;
  border-radius: 14rpx;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
}

.btn-primary {
  background: #111111;
  color: #ffffff;
}

.btn-secondary {
  background: #edf1f6;
  color: #2c3440;
}

